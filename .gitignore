# Ignore everything by default, then explicitly keep the publishable snapshot.
*

# Core repo metadata and top-level docs/scripts.
!.gitignore
!README.md
!start_garden_browser_viewer.sh

# ----------------------------
# Frontend snapshot
# ----------------------------
!gs-browser-viewer/
!gs-browser-viewer/**

# Never track installed dependencies, builds, or linked model assets.
gs-browser-viewer/node_modules/
gs-browser-viewer/dist/
gs-browser-viewer/public/assets/
gs-browser-viewer/figures/

# ----------------------------
# MEGS-2 source snapshot
# ----------------------------
!MEGS-2/
!MEGS-2/**

# Drop nested git metadata, local builds, checkpoints, and third-party submodules.
MEGS-2/.git/
MEGS-2/.git/**
MEGS-2/.git-local-backup/
MEGS-2/.git-local-backup/**
MEGS-2/**/.git/
MEGS-2/**/.git/**
MEGS-2/submodules/
MEGS-2/submodules/**
MEGS-2/**/__pycache__/
MEGS-2/**/*.pyc
MEGS-2/**/.ipynb_checkpoints/
MEGS-2/**/build/
MEGS-2/**/dist/
MEGS-2/**/output/
MEGS-2/**/output*/
MEGS-2/**/tensorboard_3d/
MEGS-2/**/screenshots/
MEGS-2/**/*.so
MEGS-2/**/*.o
MEGS-2/**/*.a

# ----------------------------
# Gaussian Splatting source snapshot
# ----------------------------
!gaussian-splatting/
!gaussian-splatting/**

# Drop nested git metadata, external deps, builds, and generated binaries.
gaussian-splatting/.git/
gaussian-splatting/.git/**
gaussian-splatting/.git-local-backup/
gaussian-splatting/.git-local-backup/**
gaussian-splatting/**/.git/
gaussian-splatting/**/.git/**
gaussian-splatting/.gitmodules
gaussian-splatting/submodules/
gaussian-splatting/submodules/**
gaussian-splatting/**/__pycache__/
gaussian-splatting/**/*.pyc
gaussian-splatting/**/build/
gaussian-splatting/**/dist/
gaussian-splatting/**/install/
gaussian-splatting/**/output/
gaussian-splatting/**/output*/
gaussian-splatting/**/tensorboard_3d/
gaussian-splatting/**/screenshots/
gaussian-splatting/SIBR_viewers/
gaussian-splatting/SIBR_viewers/**
gaussian-splatting/**/*.so
gaussian-splatting/**/*.o
gaussian-splatting/**/*.a

# ----------------------------
# Always exclude heavy local-only workspace data and results
# ----------------------------
extracted/
logs/
test/
