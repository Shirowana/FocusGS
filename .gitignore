# Ignore everything by default, then explicitly keep the publishable snapshot.
*

# Core repo metadata and top-level docs/scripts.
!.gitignore
!README.md
!docs/
!docs/**
!scripts/
!scripts/**
!frontend/
!frontend/**
!backend/
!backend/**
!algorithms/
!algorithms/**
!viewers/
!viewers/**

# ----------------------------
# Frontend snapshot
# ----------------------------
# Never track installed dependencies, builds, or linked model assets.
frontend/gs-browser-viewer/node_modules/
frontend/gs-browser-viewer/dist/
frontend/gs-browser-viewer/public/assets/
frontend/gs-browser-viewer/.runtime/
frontend/gs-browser-viewer/figures copy/

# ----------------------------
# MEGS-2 source snapshot
# ----------------------------
# Drop nested git metadata, local builds, checkpoints, and third-party submodules.
algorithms/MEGS-2/.git/
algorithms/MEGS-2/.git/**
algorithms/MEGS-2/.git-local-backup/
algorithms/MEGS-2/.git-local-backup/**
algorithms/MEGS-2/**/.git/
algorithms/MEGS-2/**/.git/**
algorithms/MEGS-2/submodules/
algorithms/MEGS-2/submodules/**
algorithms/MEGS-2/**/__pycache__/
algorithms/MEGS-2/**/*.pyc
algorithms/MEGS-2/**/.ipynb_checkpoints/
algorithms/MEGS-2/**/build/
algorithms/MEGS-2/**/dist/
algorithms/MEGS-2/**/output/
algorithms/MEGS-2/**/output*/
algorithms/MEGS-2/**/tensorboard_3d/
algorithms/MEGS-2/**/screenshots/
algorithms/MEGS-2/**/*.so
algorithms/MEGS-2/**/*.o
algorithms/MEGS-2/**/*.a

# ----------------------------
# Viewer source snapshot
# ----------------------------
viewers/web-splat/.git/
viewers/web-splat/.git/**
viewers/web-splat/target/
viewers/web-splat/public/pkg/

# ----------------------------
# Always exclude heavy local-only workspace data and results
# ----------------------------
/data/
/logs/
/runs/
